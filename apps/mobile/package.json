{
  "name": "licenseplate-mobile",
  "version": "1.0.4",
  "description": "Tracking license plates game",
  "main": "expo-router/entry",
  "license": "ISC",
  "author": "Michael Kramer",
  "email": "michaelrkramer@gmail.com",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --latest --profile production",
    "version:sync": "eas build:version:sync --platform ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^56.0.0",
    "expo-asset": "~56.0.14",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.15",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "nativewind": "^4.0.1",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true
}
