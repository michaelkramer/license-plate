{
  "expo": {
    "name": "licensePlate",
    "version": "1.0.0",
    "slug": "licenseplate",
    "scheme": "licenseplate",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "assetBundlePatterns": ["assets/**/*"],
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://n"
        }
      ],
      "expo-asset",
      "expo-image",
      "expo-splash-screen",
      "expo-status-bar"
    ]
  }
}
